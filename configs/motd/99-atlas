#!/bin/bash
# ATLAS PLATFORM — MOTD
# /etc/update-motd.d/99-atlas
# Shows hardened system summary on login

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║                    🏛️  ATLAS PLATFORM                        ║"
echo "║              Infrastructure Automation Server               ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
echo "  Hostname.....: $(hostname -f)"
echo "  OS...........: $(lsb_release -ds 2>/dev/null || cat /etc/os-release | grep PRETTY | cut -d'"' -f2)"
echo "  Kernel.......: $(uname -r)"
echo "  Uptime.......: $(uptime -p | sed 's/up //')"
echo "  Load.........: $(awk '{print $1", "$2", "$3}' /proc/loadavg)"
echo ""
echo "  ── Network ────────────────────────────────────────────────"
echo "  IPv4.........: $(hostname -I | awk '{print $1}')"
echo "  Gateway......: $(ip route show default 2>/dev/null | awk '{print $3}' | head -1)"
echo "  DNS..........: $(grep '^nameserver' /etc/resolv.conf | awk '{print $2}' | paste -sd ',')"
echo ""
echo "  ── Security ───────────────────────────────────────────────"
echo "  SSH Port.....: $(grep -oP '^Port\s+\K\d+' /etc/ssh/sshd_config /etc/ssh/sshd_config.d/*.conf 2>/dev/null | tail -1)"
echo "  UFW..........: $(ufw status 2>/dev/null | head -1 | awk '{print $2}')"
echo "  fail2ban.....: $(systemctl is-active fail2ban 2>/dev/null || echo 'inactive')"
echo "  auditd.......: $(systemctl is-active auditd 2>/dev/null || echo 'inactive')"
echo "  ZRAM.........: $(swapon --show 2>/dev/null | grep -c zram0 || echo 0) device(s)"
echo ""
echo "  ── Resources ──────────────────────────────────────────────"
echo "  Memory.......: $(free -h | awk '/^Mem:/{print $3" used / "$2" total"}')"
echo "  Disk.........: $(df -h / | awk 'NR==2{print $3" used / "$2" total ("$5" used)"}')"
echo "  Swap.........: $(free -h | awk '/^Swap:/{print $3" used / "$2" total"}')"
echo ""
echo "  ── ATLAS Status ───────────────────────────────────────────"
echo "  Hermes Agent.: $(systemctl is-active hermes 2>/dev/null || echo 'not installed')"
echo "  PM2...........: $(command -v pm2 >/dev/null && pm2 ping 2>/dev/null | grep -c 'pong' || echo 0) processes"
echo ""
echo "  📋 Deployment Log: /var/log/atlas-deploy.log"
echo ""
